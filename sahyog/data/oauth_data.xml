<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!--
            Google OAuth Provider for Sahyog.
            After deployment, update the client_id in Odoo Settings → OAuth Providers
            with your actual Google OAuth Client ID.

            To get credentials:
            1. Go to https://console.cloud.google.com/apis/credentials
            2. Create OAuth 2.0 Client ID (Web application)
            3. Authorized redirect URI: https://sahyog.online/auth_oauth/signin
            4. Copy the Client ID and paste it in Odoo Settings → OAuth Providers → Google
        -->
        <record id="provider_google_sahyog" model="auth.oauth.provider">
            <field name="name">Google</field>
            <field name="client_id">692762733255-ogiuhs66vo0f1ruamo6vl72rd88g1o93.apps.googleusercontent.com</field>
            <field name="auth_endpoint">https://accounts.google.com/o/oauth2/v2/auth</field>
            <field name="scope">openid email profile</field>
            <field name="validation_endpoint">https://www.googleapis.com/oauth2/v3/tokeninfo</field>
            <field name="data_endpoint">https://www.googleapis.com/oauth2/v3/userinfo</field>
            <field name="enabled" eval="True"/>
            <field name="css_class">fa fa-fw fa-google</field>
            <field name="body">Log in with Google</field>
            <field name="sequence">1</field>
        </record>

    </data>
</odoo>
