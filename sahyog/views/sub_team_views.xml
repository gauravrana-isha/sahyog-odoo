<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tree View -->
    <record id="view_sub_team_tree" model="ir.ui.view">
        <field name="name">sahyog.sub.team.tree</field>
        <field name="model">sahyog.sub.team</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="team_lead_id"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_sub_team_form" model="ir.ui.view">
        <field name="name">sahyog.sub.team.form</field>
        <field name="model">sahyog.sub.team</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="team_lead_id"/>
                        </group>
                        <group>
                            <field name="description"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_sub_team" model="ir.actions.act_window">
        <field name="name">Sub Teams</field>
        <field name="res_model">sahyog.sub.team</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
