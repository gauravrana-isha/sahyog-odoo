<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="view_guest_feedback_tree" model="ir.ui.view">
        <field name="name">sahyog.guest.feedback.list</field>
        <field name="model">sahyog.guest.feedback</field>
        <field name="arch" type="xml">
            <list>
                <field name="guest_name"/>
                <field name="visit_id"/>
                <field name="region_id"/>
                <field name="overall_rating" widget="badge"
                       decoration-danger="overall_rating in ('1','2')"
                       decoration-warning="overall_rating == '3'"
                       decoration-success="overall_rating in ('4','5')"/>
                <field name="would_visit_again"/>
                <field name="create_date" string="Submitted"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_guest_feedback_form" model="ir.ui.view">
        <field name="name">sahyog.guest.feedback.form</field>
        <field name="model">sahyog.guest.feedback</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group string="Visit Info">
                            <field name="visit_id"/>
                            <field name="region_id"/>
                            <field name="create_date" string="Submitted On" readonly="1"/>
                        </group>
                        <group string="Guest Details">
                            <field name="guest_name"/>
                            <field name="contact_phone"/>
                            <field name="contact_email"/>
                        </group>
                    </group>
                    <group>
                        <group string="Feedback">
                            <field name="overall_rating"/>
                            <field name="would_visit_again"/>
                            <field name="interested_in_programs"/>
                            <field name="want_to_know_initiatives"/>
                        </group>
                    </group>
                    <separator string="What did you enjoy most?"/>
                    <field name="enjoyed_most" nolabel="1"
                           placeholder="What did the guest enjoy most?"/>
                    <separator string="What could be improved?"/>
                    <field name="could_be_improved" nolabel="1"
                           placeholder="What could be improved?"/>
                    <separator string="Additional Comments"/>
                    <field name="additional_comments" nolabel="1"
                           placeholder="Any additional comments..."/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_guest_feedback_search" model="ir.ui.view">
        <field name="name">sahyog.guest.feedback.search</field>
        <field name="model">sahyog.guest.feedback</field>
        <field name="arch" type="xml">
            <search string="Search Guest Feedback">
                <field name="guest_name" string="Guest"/>
                <field name="visit_id" string="Visit"/>
                <field name="region_id" string="Region"/>
                <separator/>
                <filter string="Rating 4+" name="filter_high_rating"
                        domain="[('overall_rating', 'in', ('4','5'))]"/>
                <filter string="Rating ≤ 2" name="filter_low_rating"
                        domain="[('overall_rating', 'in', ('1','2'))]"/>
                <filter string="Would Visit Again" name="filter_visit_again"
                        domain="[('would_visit_again', '=', 'yes')]"/>
                <separator/>
                <filter string="Submitted" name="filter_submitted" date="create_date"/>
                <separator/>
                <filter string="Region" name="groupby_region"
                        domain="[]" context="{'group_by': 'region_id'}"/>
                <filter string="Overall Rating" name="groupby_rating"
                        domain="[]" context="{'group_by': 'overall_rating'}"/>
                <filter string="Month" name="groupby_month"
                        domain="[]" context="{'group_by': 'create_date:month'}"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_guest_feedback" model="ir.actions.act_window">
        <field name="name">Guest Feedback</field>
        <field name="res_model">sahyog.guest.feedback</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_guest_feedback_search"/>
    </record>

</odoo>
