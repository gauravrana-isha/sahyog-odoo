<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════════════════════
         Portal Home — Sahyog Section on /my
         ══════════════════════════════════════════════════════════════════ -->
    <!-- Portal Home — Sahyog cards removed (SPA replaces portal) -->
    <template id="portal_my_home_sahyog" name="Portal My Home — Sahyog"
              inherit_id="portal.portal_my_home" priority="40">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="before">
            <!-- Intentionally empty — volunteers use /sahyog/app instead -->
        </xpath>
    </template>

    <!-- ══════════════════════════════════════════════════════════════════
         Sahyog Sidebar Navigation (reusable)
         ══════════════════════════════════════════════════════════════════ -->
    <template id="portal_sahyog_sidebar" name="Sahyog Portal Sidebar">
        <div class="list-group mb-4">
            <a href="/my/sahyog" t-attf-class="list-group-item list-group-item-action #{'active' if page_name == 'sahyog_dashboard' else ''}">
                <i class="fa fa-tachometer me-2"/> Dashboard
            </a>
            <a href="/my/sahyog/profile" t-attf-class="list-group-item list-group-item-action #{'active' if page_name == 'sahyog_profile' else ''}">
                <i class="fa fa-user me-2"/> My Profile
            </a>
            <a href="/my/sahyog/silence" t-attf-class="list-group-item list-group-item-action #{'active' if page_name in ('sahyog_silence', 'sahyog_silence_request') else ''}">
                <i class="fa fa-moon-o me-2"/> Silence Periods
            </a>
            <a href="/my/sahyog/breaks" t-attf-class="list-group-item list-group-item-action #{'active' if page_name in ('sahyog_breaks', 'sahyog_break_request') else ''}">
                <i class="fa fa-pause-circle me-2"/> Breaks
            </a>
            <a href="/my/sahyog/programs" t-attf-class="list-group-item list-group-item-action #{'active' if page_name in ('sahyog_programs', 'sahyog_program_request') else ''}">
                <i class="fa fa-graduation-cap me-2"/> Programs
            </a>
            <a href="/my/sahyog/notifications" t-attf-class="list-group-item list-group-item-action #{'active' if page_name == 'sahyog_notifications' else ''}">
                <i class="fa fa-bell me-2"/> Notifications
            </a>
            <a href="/my/sahyog/unavailability" t-attf-class="list-group-item list-group-item-action #{'active' if page_name == 'sahyog_unavailability' else ''}">
                <i class="fa fa-calendar-times-o me-2"/> Unavailability
            </a>
        </div>
        <a href="/my" class="btn btn-outline-secondary btn-sm w-100">
            <i class="fa fa-arrow-left me-1"/> Back to Portal Home
        </a>
    </template>

    <!-- ══════════════════════════════════════════════════════════════════
         Sahyog Portal Layout Wrapper (sidebar + content)
         ══════════════════════════════════════════════════════════════════ -->
    <template id="portal_sahyog_layout" name="Sahyog Portal Layout">
        <t t-call="portal.portal_layout">
            <div class="o_portal_wrap">
                <div class="container mt-3">
                    <div class="row">
                        <div class="col-lg-3 col-md-4 mb-3">
                            <t t-call="sahyog.portal_sahyog_sidebar"/>
                        </div>
                        <div class="col-lg-9 col-md-8">
                            <t t-raw="0"/>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- ══════════════════════════════════════════════════════════════════
         Dashboard
         ══════════════════════════════════════════════════════════════════ -->
    <template id="portal_my_dashboard" name="My Sahyog Dashboard">
        <t t-call="sahyog.portal_sahyog_layout">
            <h3>My Sahyog Dashboard</h3>

            <!-- Status & Summary -->
            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <div class="card text-center">
                        <div class="card-body">
                            <h6 class="card-title text-muted">Current Status</h6>
                            <p class="fs-4 fw-bold mb-0">
                                <t t-esc="volunteer.computed_status or 'Available'"/>
                            </p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card text-center">
                        <div class="card-body">
                            <h6 class="card-title text-muted">Completed Programs</h6>
                            <p class="fs-4 fw-bold mb-0"><t t-esc="completed_programs"/></p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card text-center">
                        <div class="card-body">
                            <h6 class="card-title text-muted">Quick Actions</h6>
                            <a href="/my/sahyog/silence/request" class="btn btn-sm btn-outline-warning me-1">Request Silence</a>
                            <a href="/my/sahyog/breaks/request" class="btn btn-sm btn-outline-info">Request Break</a>
                        </div>
                    </div>
                </div>
            </div>

            <h5 class="mb-3">Upcoming Entries</h5>
            <t t-if="upcoming_silences">
                <h6 class="text-muted">Silence Periods</h6>
                <table class="table table-sm mb-3">
                    <thead><tr><th>Start</th><th>End</th><th>Type</th><th>Status</th></tr></thead>
                    <tbody>
                        <t t-foreach="upcoming_silences" t-as="s">
                            <tr><td><t t-esc="s.start_date"/></td><td><t t-esc="s.end_date"/></td><td><t t-esc="s.silence_type"/></td><td><t t-esc="s.status"/></td></tr>
                        </t>
                    </tbody>
                </table>
            </t>
            <t t-if="upcoming_breaks">
                <h6 class="text-muted">Break Periods</h6>
                <table class="table table-sm mb-3">
                    <thead><tr><th>Start</th><th>End</th><th>Type</th><th>Status</th></tr></thead>
                    <tbody>
                        <t t-foreach="upcoming_breaks" t-as="b">
                            <tr><td><t t-esc="b.start_date"/></td><td><t t-esc="b.end_date"/></td><td><t t-esc="b.break_type"/></td><td><t t-esc="b.status"/></td></tr>
                        </t>
                    </tbody>
                </table>
            </t>
            <t t-if="upcoming_programs">
                <h6 class="text-muted">Program Enrollments</h6>
                <table class="table table-sm mb-3">
                    <thead><tr><th>Program</th><th>Start</th><th>End</th><th>Status</th></tr></thead>
                    <tbody>
                        <t t-foreach="upcoming_programs" t-as="p">
                            <tr><td><t t-esc="p.program_id.name"/></td><td><t t-esc="p.start_date"/></td><td><t t-esc="p.end_date"/></td><td><t t-esc="p.completion_status"/></td></tr>
                        </t>
                    </tbody>
                </table>
            </t>
            <t t-if="not upcoming_silences and not upcoming_breaks and not upcoming_programs">
                <p class="text-muted">No upcoming entries.</p>
            </t>
        </t>
    </template>

    <!-- ══════════════════════════════════════════════════════════════════
         Profile
         ══════════════════════════════════════════════════════════════════ -->
    <template id="portal_my_profile" name="My Sahyog Profile">
        <t t-call="sahyog.portal_sahyog_layout">
            <h3>My Profile</h3>
            <t t-if="success"><div class="alert alert-success">Profile updated successfully.</div></t>
            <t t-if="error"><div class="alert alert-danger"><t t-esc="error"/></div></t>
            <div class="card">
                <div class="card-body">
                    <dl class="row mb-3">
                        <dt class="col-sm-4">Name</dt><dd class="col-sm-8"><t t-esc="volunteer.name"/></dd>
                        <dt class="col-sm-4">Email</dt><dd class="col-sm-8"><t t-esc="volunteer.work_email"/></dd>
                        <dt class="col-sm-4">Status</dt><dd class="col-sm-8"><t t-esc="volunteer.computed_status"/></dd>
                    </dl>
                    <form method="post" action="/my/sahyog/profile">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <div class="mb-3"><label class="form-label">Phone</label><input type="text" name="phone" class="form-control" t-att-value="volunteer.phone or ''"/></div>
                        <div class="mb-3"><label class="form-label">WhatsApp Number</label><input type="text" name="whatsapp_number" class="form-control" t-att-value="volunteer.whatsapp_number or ''"/></div>
                        <div class="mb-3"><label class="form-label">Special Skills</label><textarea name="special_skills" class="form-control" rows="3"><t t-esc="volunteer.special_skills or ''"/></textarea></div>
                        <div class="mb-3"><label class="form-label">Health Conditions</label><textarea name="health_conditions" class="form-control" rows="3"><t t-esc="volunteer.health_conditions or ''"/></textarea></div>
                        <h5 class="mt-4">Emergency Contact</h5>
                        <div class="mb-3"><label class="form-label">Name</label><input type="text" name="emergency_contact_name" class="form-control" t-att-value="volunteer.emergency_contact_name or ''"/></div>
                        <div class="mb-3"><label class="form-label">Phone</label><input type="text" name="emergency_contact_phone" class="form-control" t-att-value="volunteer.emergency_contact_phone or ''"/></div>
                        <div class="mb-3"><label class="form-label">Relation</label><input type="text" name="emergency_contact_relation" class="form-control" t-att-value="volunteer.emergency_contact_relation or ''"/></div>
                        <button type="submit" class="btn btn-primary">Save</button>
                    </form>
                </div>
            </div>
        </t>
    </template>

    <!-- ══════════════════════════════════════════════════════════════════
         Silence Periods
         ══════════════════════════════════════════════════════════════════ -->
    <template id="portal_my_silence" name="My Silence Periods">
        <t t-call="sahyog.portal_sahyog_layout">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h3>My Silence Periods</h3>
                <a href="/my/sahyog/silence/request" class="btn btn-primary btn-sm">Request Silence</a>
            </div>
            <t t-if="not silences"><p class="text-muted">No silence periods found.</p></t>
            <t t-if="silences">
                <table class="table table-sm">
                    <thead><tr><th>Start</th><th>End</th><th>Type</th><th>Status</th></tr></thead>
                    <tbody><t t-foreach="silences" t-as="s"><tr><td><t t-esc="s.start_date"/></td><td><t t-esc="s.end_date"/></td><td><t t-esc="s.silence_type"/></td><td><t t-esc="s.status"/></td></tr></t></tbody>
                </table>
            </t>
        </t>
    </template>

    <template id="portal_silence_request" name="Request Silence Period">
        <t t-call="sahyog.portal_sahyog_layout">
            <h3>Request Silence Period</h3>
            <t t-if="error"><div class="alert alert-danger"><t t-esc="error"/></div></t>
            <form method="post" action="/my/sahyog/silence/request">
                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                <div class="mb-3"><label class="form-label">Start Date</label><input type="date" name="start_date" class="form-control" required="required"/></div>
                <div class="mb-3"><label class="form-label">End Date</label><input type="date" name="end_date" class="form-control" required="required"/></div>
                <div class="mb-3"><label class="form-label">Silence Type</label>
                    <select name="silence_type" class="form-select"><option value="personal">Personal</option><option value="9pm_9am">9PM-9AM Silence</option><option value="program">Program Silence</option></select>
                </div>
                <div class="mb-3"><label class="form-label">Notes</label><textarea name="notes" class="form-control" rows="3"></textarea></div>
                <button type="submit" class="btn btn-primary">Submit Request</button>
                <a href="/my/sahyog/silence" class="btn btn-secondary ms-2">Cancel</a>
            </form>
        </t>
    </template>

    <!-- ══════════════════════════════════════════════════════════════════
         Break Periods
         ══════════════════════════════════════════════════════════════════ -->
    <template id="portal_my_breaks" name="My Break Periods">
        <t t-call="sahyog.portal_sahyog_layout">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h3>My Break Periods</h3>
                <a href="/my/sahyog/breaks/request" class="btn btn-primary btn-sm">Request Break</a>
            </div>
            <t t-if="not breaks"><p class="text-muted">No break periods found.</p></t>
            <t t-if="breaks">
                <table class="table table-sm">
                    <thead><tr><th>Start</th><th>End</th><th>Type</th><th>Status</th></tr></thead>
                    <tbody><t t-foreach="breaks" t-as="b"><tr><td><t t-esc="b.start_date"/></td><td><t t-esc="b.end_date"/></td><td><t t-esc="b.break_type"/></td><td><t t-esc="b.status"/></td></tr></t></tbody>
                </table>
            </t>
        </t>
    </template>

    <template id="portal_break_request" name="Request Break Period">
        <t t-call="sahyog.portal_sahyog_layout">
            <h3>Request Break Period</h3>
            <t t-if="error"><div class="alert alert-danger"><t t-esc="error"/></div></t>
            <form method="post" action="/my/sahyog/breaks/request">
                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                <div class="mb-3"><label class="form-label">Break Type</label>
                    <select name="break_type" class="form-select" required="required"><option value="personal">Personal</option><option value="health">Health</option><option value="family_emergency">Family Emergency</option></select>
                </div>
                <div class="mb-3"><label class="form-label">Start Date</label><input type="date" name="start_date" class="form-control" required="required"/></div>
                <div class="mb-3"><label class="form-label">End Date</label><input type="date" name="end_date" class="form-control" required="required"/></div>
                <div class="mb-3"><label class="form-label">Reason</label><textarea name="reason" class="form-control" rows="3"></textarea></div>
                <div class="mb-3"><label class="form-label">Notes</label><textarea name="notes" class="form-control" rows="2"></textarea></div>
                <button type="submit" class="btn btn-primary">Submit Request</button>
                <a href="/my/sahyog/breaks" class="btn btn-secondary ms-2">Cancel</a>
            </form>
        </t>
    </template>

    <!-- ══════════════════════════════════════════════════════════════════
         Programs
         ══════════════════════════════════════════════════════════════════ -->
    <template id="portal_my_programs" name="My Program Enrollments">
        <t t-call="sahyog.portal_sahyog_layout">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h3>My Programs</h3>
                <a href="/my/sahyog/programs/request" class="btn btn-primary btn-sm">Request Enrollment</a>
            </div>
            <t t-if="not enrollments"><p class="text-muted">No program enrollments found.</p></t>
            <t t-if="enrollments">
                <table class="table table-sm">
                    <thead><tr><th>Program</th><th>Start</th><th>End</th><th>Type</th><th>Status</th></tr></thead>
                    <tbody><t t-foreach="enrollments" t-as="e"><tr><td><t t-esc="e.program_id.name"/></td><td><t t-esc="e.start_date"/></td><td><t t-esc="e.end_date"/></td><td><t t-esc="e.participation_type"/></td><td><t t-esc="e.completion_status"/></td></tr></t></tbody>
                </table>
            </t>
        </t>
    </template>

    <template id="portal_program_request" name="Request Program Enrollment">
        <t t-call="sahyog.portal_sahyog_layout">
            <h3>Request Program Enrollment</h3>
            <t t-if="error"><div class="alert alert-danger"><t t-esc="error"/></div></t>
            <form method="post" action="/my/sahyog/programs/request">
                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                <div class="mb-3"><label class="form-label">Program</label>
                    <select name="program_id" class="form-select" required="required"><option value="">-- Select Program --</option><t t-foreach="programs" t-as="p"><option t-att-value="p.id"><t t-esc="p.name"/></option></t></select>
                </div>
                <div class="mb-3"><label class="form-label">Participation Type</label>
                    <select name="participation_type" class="form-select" required="required"><option value="participant">Participant</option><option value="volunteer">Volunteer</option></select>
                </div>
                <div class="mb-3"><label class="form-label">Start Date</label><input type="date" name="start_date" class="form-control" required="required"/></div>
                <div class="mb-3"><label class="form-label">End Date</label><input type="date" name="end_date" class="form-control" required="required"/></div>
                <div class="mb-3"><label class="form-label">Location</label><input type="text" name="location" class="form-control"/></div>
                <div class="mb-3"><label class="form-label">Notes</label><textarea name="notes" class="form-control" rows="3"></textarea></div>
                <button type="submit" class="btn btn-primary">Submit Request</button>
                <a href="/my/sahyog/programs" class="btn btn-secondary ms-2">Cancel</a>
            </form>
        </t>
    </template>

    <!-- ══════════════════════════════════════════════════════════════════
         Notifications
         ══════════════════════════════════════════════════════════════════ -->
    <template id="portal_my_notifications" name="My Notifications">
        <t t-call="sahyog.portal_sahyog_layout">
            <h3>My Notifications</h3>
            <t t-if="not notifications"><p class="text-muted">No notifications.</p></t>
            <t t-if="notifications">
                <div class="list-group">
                    <t t-foreach="notifications" t-as="n">
                        <div t-attf-class="list-group-item #{'list-group-item-light' if n.is_read else 'list-group-item-info'}">
                            <div class="d-flex justify-content-between"><strong><t t-esc="n.title"/></strong><small><t t-esc="n.create_date"/></small></div>
                            <p class="mb-1"><t t-esc="n.message"/></p>
                            <t t-if="not n.is_read"><a t-attf-href="/my/sahyog/notifications?mark_read=#{n.id}" class="btn btn-sm btn-outline-primary">Mark as Read</a></t>
                        </div>
                    </t>
                </div>
            </t>
        </t>
    </template>

    <!-- ══════════════════════════════════════════════════════════════════
         Unavailability
         ══════════════════════════════════════════════════════════════════ -->
    <template id="portal_my_unavailability" name="My Unavailability">
        <t t-call="sahyog.portal_sahyog_layout">
            <h3>My Unavailability Slots</h3>
            <t t-if="success"><div class="alert alert-success">Slot created successfully.</div></t>
            <t t-if="error"><div class="alert alert-danger"><t t-esc="error"/></div></t>
            <div class="card mb-4">
                <div class="card-header">Add Unavailability Slot</div>
                <div class="card-body">
                    <form method="post" action="/my/sahyog/unavailability">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <div class="row">
                            <div class="col-md-3 mb-2"><label class="form-label">Date</label><input type="date" name="date" class="form-control" required="required"/></div>
                            <div class="col-md-2 mb-2"><label class="form-label">Start</label><input type="time" name="start_time" class="form-control" required="required"/></div>
                            <div class="col-md-2 mb-2"><label class="form-label">End</label><input type="time" name="end_time" class="form-control" required="required"/></div>
                            <div class="col-md-3 mb-2"><label class="form-label">Reason</label><input type="text" name="reason" class="form-control"/></div>
                            <div class="col-md-2 mb-2 d-flex align-items-end"><button type="submit" class="btn btn-primary w-100">Add</button></div>
                        </div>
                    </form>
                </div>
            </div>
            <t t-if="not slots"><p class="text-muted">No unavailability slots.</p></t>
            <t t-if="slots">
                <table class="table table-sm">
                    <thead><tr><th>Date</th><th>Start</th><th>End</th><th>Reason</th><th></th></tr></thead>
                    <tbody><t t-foreach="slots" t-as="slot"><tr><td><t t-esc="slot.date"/></td><td><t t-esc="slot.start_time"/></td><td><t t-esc="slot.end_time"/></td><td><t t-esc="slot.reason or ''"/></td><td><a t-attf-href="/my/sahyog/unavailability?delete=#{slot.id}" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this slot?');">Delete</a></td></tr></t></tbody>
                </table>
            </t>
        </t>
    </template>

</odoo>
