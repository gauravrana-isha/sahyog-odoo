<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="view_meeting_tree" model="ir.ui.view">
        <field name="name">sahyog.meeting.list</field>
        <field name="model">sahyog.meeting</field>
        <field name="arch" type="xml">
            <list decoration-info="status == 'scheduled'"
                  decoration-success="status == 'completed'"
                  decoration-danger="status == 'cancelled'">
                <field name="title"/>
                <field name="volunteer_id"/>
                <field name="meeting_with_id"/>
                <field name="date"/>
                <field name="start_time"/>
                <field name="end_time"/>
                <field name="status" widget="badge"
                       decoration-info="status == 'scheduled'"
                       decoration-success="status == 'completed'"
                       decoration-danger="status == 'cancelled'"/>
                <field name="location" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_meeting_form" model="ir.ui.view">
        <field name="name">sahyog.meeting.form</field>
        <field name="model">sahyog.meeting</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="status" widget="statusbar"
                           statusbar_visible="scheduled,completed"/>
                </header>
                <sheet>
                    <group>
                        <group string="Meeting Details">
                            <field name="title" placeholder="Meeting subject"/>
                            <field name="volunteer_id"/>
                            <field name="meeting_with_id"/>
                        </group>
                        <group string="Date, Time &amp; Location">
                            <field name="date"/>
                            <field name="start_time" placeholder="HH:MM"/>
                            <field name="end_time" placeholder="HH:MM"/>
                            <field name="location" placeholder="e.g. Conference Room"/>
                        </group>
                    </group>
                    <group>
                        <group string="Administration">
                            <field name="created_by" readonly="1"/>
                        </group>
                    </group>
                    <separator string="Notes"/>
                    <field name="notes" placeholder="Meeting notes..."
                           nolabel="1"/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Calendar View -->
    <record id="view_meeting_calendar" model="ir.ui.view">
        <field name="name">sahyog.meeting.calendar</field>
        <field name="model">sahyog.meeting</field>
        <field name="arch" type="xml">
            <calendar string="Meetings" date_start="date" color="status"
                      event_open_popup="true">
                <field name="title"/>
                <field name="volunteer_id"/>
                <field name="meeting_with_id"/>
                <field name="start_time"/>
                <field name="end_time"/>
                <field name="status"/>
            </calendar>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_meeting_search" model="ir.ui.view">
        <field name="name">sahyog.meeting.search</field>
        <field name="model">sahyog.meeting</field>
        <field name="arch" type="xml">
            <search string="Search Meetings">
                <field name="title" string="Title"/>
                <field name="volunteer_id" string="Volunteer"/>
                <field name="meeting_with_id" string="Meeting With"/>
                <separator/>
                <filter string="Scheduled" name="filter_scheduled" domain="[('status', '=', 'scheduled')]"/>
                <filter string="Completed" name="filter_completed" domain="[('status', '=', 'completed')]"/>
                <filter string="Cancelled" name="filter_cancelled" domain="[('status', '=', 'cancelled')]"/>
                <separator/>
                <filter string="Date" name="filter_date" date="date"/>
                <separator/>
                <filter string="Volunteer" name="groupby_volunteer_id" domain="[]" context="{'group_by': 'volunteer_id'}"/>
                <filter string="Status" name="groupby_status" domain="[]" context="{'group_by': 'status'}"/>
                <filter string="Month" name="groupby_date_month" domain="[]" context="{'group_by': 'date:month'}"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_meeting" model="ir.actions.act_window">
        <field name="name">Meetings</field>
        <field name="res_model">sahyog.meeting</field>
        <field name="view_mode">list,form,calendar</field>
        <field name="search_view_id" ref="view_meeting_search"/>
    </record>

</odoo>
