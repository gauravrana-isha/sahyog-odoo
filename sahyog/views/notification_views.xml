<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="view_notification_tree" model="ir.ui.view">
        <field name="name">sahyog.notification.list</field>
        <field name="model">sahyog.notification</field>
        <field name="arch" type="xml">
            <list decoration-bf="not is_read"
                  decoration-muted="is_read">
                <field name="create_date" string="Date"/>
                <field name="volunteer_id"/>
                <field name="type" widget="badge"/>
                <field name="title"/>
                <field name="is_read" widget="boolean_toggle"/>
                <field name="email_sent" optional="hide"/>
                <button name="action_mark_read" string="Mark as Read"
                        type="object" icon="fa-check"
                        invisible="is_read"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_notification_form" model="ir.ui.view">
        <field name="name">sahyog.notification.form</field>
        <field name="model">sahyog.notification</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_mark_read" string="Mark as Read"
                            type="object" class="btn-primary"
                            invisible="is_read"/>
                </header>
                <sheet>
                    <group>
                        <group string="Notification">
                            <field name="volunteer_id"/>
                            <field name="type"/>
                            <field name="title"/>
                        </group>
                        <group string="Status">
                            <field name="is_read"/>
                            <field name="email_sent"/>
                            <field name="create_date" string="Sent On"/>
                        </group>
                    </group>
                    <separator string="Message"/>
                    <field name="message" nolabel="1" readonly="1"/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_notification_search" model="ir.ui.view">
        <field name="name">sahyog.notification.search</field>
        <field name="model">sahyog.notification</field>
        <field name="arch" type="xml">
            <search string="Search Notifications">
                <field name="volunteer_id" string="Volunteer"/>
                <field name="title" string="Title"/>
                <separator/>
                <filter string="Unread" name="filter_unread" domain="[('is_read', '=', False)]"/>
                <filter string="Read" name="filter_read" domain="[('is_read', '=', True)]"/>
                <filter string="Email Sent" name="filter_email_sent" domain="[('email_sent', '=', True)]"/>
                <separator/>
                <filter string="Date" name="filter_date" date="create_date"/>
                <separator/>
                <filter string="Volunteer" name="groupby_volunteer_id" domain="[]" context="{'group_by': 'volunteer_id'}"/>
                <filter string="Type" name="groupby_type" domain="[]" context="{'group_by': 'type'}"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_notification" model="ir.actions.act_window">
        <field name="name">Notifications</field>
        <field name="res_model">sahyog.notification</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_notification_search"/>
    </record>

</odoo>
