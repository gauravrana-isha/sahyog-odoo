<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="view_guest_place_tree" model="ir.ui.view">
        <field name="name">sahyog.guest.place.list</field>
        <field name="model">sahyog.guest.place</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="center_id"/>
                <field name="sort_order"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_guest_place_form" model="ir.ui.view">
        <field name="name">sahyog.guest.place.form</field>
        <field name="model">sahyog.guest.place</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="center_id"/>
                            <field name="sort_order"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_guest_place_search" model="ir.ui.view">
        <field name="name">sahyog.guest.place.search</field>
        <field name="model">sahyog.guest.place</field>
        <field name="arch" type="xml">
            <search string="Search Guest Places">
                <field name="name"/>
                <field name="center_id"/>
                <separator/>
                <filter string="Center" name="groupby_center"
                        domain="[]" context="{'group_by': 'center_id'}"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_guest_place" model="ir.actions.act_window">
        <field name="name">Guest Places / Events</field>
        <field name="res_model">sahyog.guest.place</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_guest_place_search"/>
    </record>

</odoo>
