<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="view_program_tree" model="ir.ui.view">
        <field name="name">sahyog.program.list</field>
        <field name="model">sahyog.program</field>
        <field name="arch" type="xml">
            <list js_class="program_list_with_sheet">
                <field name="name" string="Program"/>
                <field name="program_type" widget="badge"
                       decoration-info="program_type == 'main'"
                       decoration-success="program_type == 'silence'"
                       decoration-muted="program_type == 'other'"/>
                <field name="gender" optional="show"/>
                <field name="typical_duration_days" string="Duration (days)"/>
                <field name="prerequisite_ids" widget="many2many_tags" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_program_form" model="ir.ui.view">
        <field name="name">sahyog.program.form</field>
        <field name="model">sahyog.program</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Program Name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Details">
                            <field name="program_type"/>
                            <field name="gender"/>
                            <field name="typical_duration_days" string="Duration (days)"/>
                        </group>
                        <group string="Prerequisites">
                            <field name="prerequisite_ids" widget="many2many_tags"
                                   nolabel="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description" name="description">
                            <field name="description" nolabel="1"
                                   placeholder="Describe the program..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_program_search" model="ir.ui.view">
        <field name="name">sahyog.program.search</field>
        <field name="model">sahyog.program</field>
        <field name="arch" type="xml">
            <search string="Search Programs">
                <field name="name"/>
                <separator/>
                <filter string="Main" name="filter_main" domain="[('program_type', '=', 'main')]"/>
                <filter string="Silence" name="filter_silence" domain="[('program_type', '=', 'silence')]"/>
                <filter string="Other" name="filter_other" domain="[('program_type', '=', 'other')]"/>
                <separator/>
                <filter string="Male" name="filter_male" domain="[('gender', '=', 'male')]"/>
                <filter string="Female" name="filter_female" domain="[('gender', '=', 'female')]"/>
                <separator/>
                <filter string="Type" name="groupby_type" domain="[]" context="{'group_by': 'program_type'}"/>
                <filter string="Gender" name="groupby_gender" domain="[]" context="{'group_by': 'gender'}"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_program" model="ir.actions.act_window">
        <field name="name">Programs</field>
        <field name="res_model">sahyog.program</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_program_search"/>
    </record>

</odoo>
