<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="view_program_schedule_tree" model="ir.ui.view">
        <field name="name">sahyog.program.schedule.list</field>
        <field name="model">sahyog.program.schedule</field>
        <field name="arch" type="xml">
            <list js_class="program_list_with_sheet" decoration-info="schedule_status == 'upcoming'"
                  decoration-muted="schedule_status == 'completed'">
                <field name="program_id"/>
                <field name="location"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="capacity"/>
                <field name="schedule_status" widget="badge"
                       decoration-info="schedule_status == 'upcoming'"
                       decoration-success="schedule_status == 'completed'"
                       decoration-muted="schedule_status == 'planning'"/>
                <field name="fee" optional="hide"/>
                <field name="is_recurring" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_program_schedule_form" model="ir.ui.view">
        <field name="name">sahyog.program.schedule.form</field>
        <field name="model">sahyog.program.schedule</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="schedule_status" widget="statusbar"
                           statusbar_visible="planning,upcoming,completed"/>
                </header>
                <sheet>
                    <group>
                        <group string="Program &amp; Venue">
                            <field name="program_id"/>
                            <field name="location" placeholder="e.g. Isha Yoga Center"/>
                            <field name="capacity"/>
                            <field name="fee" placeholder="e.g. Free / ₹500"/>
                        </group>
                        <group string="Dates &amp; Times">
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="start_time" placeholder="HH:MM"/>
                            <field name="end_time" placeholder="HH:MM"/>
                            <field name="is_recurring"/>
                        </group>
                    </group>
                    <separator string="Notes"/>
                    <field name="notes" placeholder="Schedule notes..."
                           nolabel="1"/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_program_schedule_search" model="ir.ui.view">
        <field name="name">sahyog.program.schedule.search</field>
        <field name="model">sahyog.program.schedule</field>
        <field name="arch" type="xml">
            <search string="Search Program Schedules">
                <field name="program_id" string="Program"/>
                <field name="location" string="Location"/>
                <separator/>
                <filter string="Planning" name="filter_planning" domain="[('schedule_status', '=', 'planning')]"/>
                <filter string="Upcoming" name="filter_upcoming" domain="[('schedule_status', '=', 'upcoming')]"/>
                <filter string="Completed" name="filter_completed" domain="[('schedule_status', '=', 'completed')]"/>
                <separator/>
                <filter string="Start Date" name="filter_start_date" date="start_date"/>
                <filter string="End Date" name="filter_end_date" date="end_date"/>
                <separator/>
                <filter string="Program" name="groupby_program" domain="[]" context="{'group_by': 'program_id'}"/>
                <filter string="Status" name="groupby_status" domain="[]" context="{'group_by': 'schedule_status'}"/>
                <filter string="Location" name="groupby_location" domain="[]" context="{'group_by': 'location'}"/>
                <filter string="Month" name="groupby_month" domain="[]" context="{'group_by': 'start_date:month'}"/>
            </search>
        </field>
    </record>

    <!-- Pivot View -->
    <record id="view_program_schedule_pivot" model="ir.ui.view">
        <field name="name">sahyog.program.schedule.pivot</field>
        <field name="model">sahyog.program.schedule</field>
        <field name="arch" type="xml">
            <pivot string="Schedule Analysis">
                <field name="program_id" type="row"/>
                <field name="schedule_status" type="col"/>
            </pivot>
        </field>
    </record>

    <!-- Graph View -->
    <record id="view_program_schedule_graph" model="ir.ui.view">
        <field name="name">sahyog.program.schedule.graph</field>
        <field name="model">sahyog.program.schedule</field>
        <field name="arch" type="xml">
            <graph string="Schedule Analysis" type="bar">
                <field name="schedule_status"/>
            </graph>
        </field>
    </record>

    <!-- Action -->
    <record id="action_program_schedule" model="ir.actions.act_window">
        <field name="name">Program Schedules</field>
        <field name="res_model">sahyog.program.schedule</field>
        <field name="view_mode">list,form,pivot,graph</field>
        <field name="search_view_id" ref="view_program_schedule_search"/>
    </record>

</odoo>
