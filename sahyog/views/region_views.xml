<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tree View -->
    <record id="view_region_tree" model="ir.ui.view">
        <field name="name">sahyog.region.tree</field>
        <field name="model">sahyog.region</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="nationality"/>
                <field name="sort_order"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_region_form" model="ir.ui.view">
        <field name="name">sahyog.region.form</field>
        <field name="model">sahyog.region</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="nationality"/>
                        </group>
                        <group>
                            <field name="sort_order"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_region" model="ir.actions.act_window">
        <field name="name">Regions</field>
        <field name="res_model">sahyog.region</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
